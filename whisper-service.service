[Unit]
Description=Whisper Validation Service for Bray Music Studio
After=network.target

[Service]
Type=simple
User=bobray
WorkingDirectory=/home/bobray/ace-step
ExecStart=/home/bobray/.local/bin/uvicorn whisper_service:app --host 0.0.0.0 --port 7862
Restart=on-failure
RestartSec=10
Environment=PATH=/home/bobray/.local/bin:/usr/local/bin:/usr/bin:/bin

[Install]
WantedBy=multi-user.target
